@inproceedings{marquezQualityConcernsWhena_2025, title={Quality concerns when integrating quantum and classical computing: a systematic mapping study}, rights={Copyright (c)}, ISSN={0000-0000}, url={https://sol.sbc.org.br/index.php/cibse/article/view/35330}, DOI={10.5753/cibse.2025.35330}, abstractNote={This article presents a systematic mapping review to categorize software quality research for hybrid computing systems; meaning the combination of classical software and quantum technologies to solve a problem. This work attempts to categorize primary studies with respect to quality attributes and metrics in hybrid systems reported in state of the art literature. Moreover, it identifies potential research areas and surveys the challenges of the practical integration of quantum software into classical infrastructures.}, booktitle={Congresso Ibero-Americano em Engenharia de Software (CIbSE)}, publisher={SBC}, author={Marquez, Cristian and Ojeda, Johana and Garcés, Kelly}, year={2025}, month=may, pages={380–381}, language={en} }


