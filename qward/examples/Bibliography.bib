nequalities and pioneering quantum}, number={01}, journal={Journal of Nonlinear Analysis and Optimization}, publisher={Marubhoomi Shodh sanstan}, author={Saini, Rajkumar and Sewada, Ranu and Arora, Aaryan}, year={2023}, pages={26–35}, language={en} }

